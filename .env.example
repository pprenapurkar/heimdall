# ─────────────────────────────────────────────────────────────────────────────
# TraceJudge environment configuration
# Copy to .env.local for local development.
# ─────────────────────────────────────────────────────────────────────────────

# --- Database connection mode --------------------------------------------------
# local    -> plain pg driver against the Docker pgvector container (this repo)
# data-api -> AWS RDS Data API against Aurora PostgreSQL (production on Vercel)
DB_MODE=local

# Local pg connection (Docker, see docker-compose.yml). Note: host port is 5433.
DATABASE_URL=postgres://tracejudge:tracejudge@localhost:5433/tracejudge

# --- RDS Data API (production only; ignored when DB_MODE=local) -----------------
# Auth comes from Vercel Marketplace OIDC -> AWS; do NOT commit AWS keys.
AURORA_CLUSTER_ARN=
AURORA_SECRET_ARN=
AURORA_DATABASE=tracejudge
AWS_REGION=us-east-1

# --- Embeddings ----------------------------------------------------------------
# local     -> deterministic feature-hashing embeddings, zero API keys (default)
# openai    -> OpenAI text-embedding-3-small (requires OPENAI_API_KEY)
# aurora_ml -> aws_bedrock.invoke_model_get_embeddings, computed inside Aurora SQL
EMBEDDING_PROVIDER=local
EMBEDDING_DIM=1536
OPENAI_API_KEY=

# Bedrock model ids used by the aurora_ml path (production)
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0
BEDROCK_TEXT_MODEL=anthropic.claude-3-haiku-20240307-v1:0

# --- Drift engine tuning -------------------------------------------------------
# Cosine DISTANCE (1 - cosine similarity) above which an event is "semantic_drift".
# Calibrated to the embedding provider's scale:
#   local feature-hashing -> on-task ~0.70, off-task ~0.90+  => use 0.80
#   openai / aurora_ml     -> on-task ~0.25, off-task ~0.55+  => use 0.45 (spec value)
SEMANTIC_DRIFT_THRESHOLD=0.80
# Circuit-breaker (X3): drift halt sits above the detect threshold so only severe
# divergence trips it; for openai/aurora_ml use 0.75 per spec.
CB_DRIFT_SCORE_HALT=0.90
CB_MAX_ERRORS=3

# Default tenant used by seed + demo (synthetic).
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001
